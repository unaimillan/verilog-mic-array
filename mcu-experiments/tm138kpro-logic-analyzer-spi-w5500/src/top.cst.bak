// IO_LOC "sys_clk_50mhz"   P16;
IO_LOC "sys_clk_50mhz"   P16;
IO_LOC "som_usr_sys_rst" U4;
IO_LOC "sfp0_tx_disable" R18;
IO_LOC "sfp0_rx_loss"    V18;
IO_LOC "sfp1_tx_disable" M20;
IO_LOC "sfp1_rx_loss"    W18;

IO_LOC "dock_btn[0]" K16;
IO_LOC "dock_btn[1]" F15;
IO_LOC "dock_btn[2]" G15;
IO_LOC "dock_btn[3]" G16;

IO_LOC "dock_led[0]" J14;
