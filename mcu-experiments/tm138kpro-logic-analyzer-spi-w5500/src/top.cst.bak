IO_LOC "gpio[40]" V22; // SDRAM_A3


IO_PORT "sys_clk_50mhz"   IO_TYPE=LVCMOS33 PULL_MODE=NONE         BANK_VCCIO=3.3;
IO_PORT "som_usr_sys_rst" IO_TYPE=LVCMOS33 PULL_MODE=NONE         BANK_VCCIO=3.3;
// CLOCK_LOC "sys_clk_50mhz_d" BUFG = CLK; // ????????

